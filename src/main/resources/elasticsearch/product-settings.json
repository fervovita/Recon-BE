{
  "analysis": {
    "analyzer": {
      "nori_analyzer": {
        "type": "custom",
        "tokenizer": "nori_tokenizer",
        "filter": [
          "lowercase",
          "nori_part_of_speech_filter"
        ]
      },
      "autocomplete_analyzer": {
        "type": "custom",
        "tokenizer": "autocomplete_tokenizer",
        "filter": [
          "lowercase"
        ]
      },
      "autocomplete_search_analyzer": {
        "type": "custom",
        "tokenizer": "standard",
        "filter": [
          "lowercase"
        ]
      }
    },
    "tokenizer": {
      "autocomplete_tokenizer": {
        "type": "edge_ngram",
        "min_gram": 1,
        "max_gram": 20,
        "token_chars": [
          "letter",
          "digit"
        ]
      }
    },
    "filter": {
      "nori_part_of_speech_filter": {
        "type": "nori_part_of_speech",
        "stoptags": [
          "E",
          "J",
          "SC",
          "SE",
          "SF",
          "SP",
          "SSC",
          "SSO",
          "SY",
          "VCN",
          "VCP",
          "VSV",
          "VX",
          "XPN",
          "XSA",
          "XSN",
          "XSV"
        ]
      }
    }
  }
}